# Keystatic GitHub OAuth Configuration
# For multiple editors to access the CMS, you need to create a GitHub OAuth App

# 1. Go to https://github.com/settings/developers
# 2. Click "New OAuth App"
# 3. Fill in:
#    - Application name: QuCS Keystatic CMS
#    - Homepage URL: https://www.qucs.info (or your deployment URL)
#    - Authorization callback URL: https://www.qucs.info/api/keystatic/github/oauth/callback
# 4. After creating, copy the Client ID and generate a Client Secret

KEYSTATIC_GITHUB_CLIENT_ID=your_github_client_id_here
KEYSTATIC_GITHUB_CLIENT_SECRET=your_github_client_secret_here
KEYSTATIC_SECRET=your_random_secret_key_here

# GitHub App Slug (optional, for better UI)
PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=qucs-keystatic
