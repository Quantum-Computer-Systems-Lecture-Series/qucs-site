---
export const prerender = true

import BaseLayout from '../layouts/BaseLayout.astro'
import { SITE_BASE } from '../consts'
import { Icon } from 'astro-icon/components'
import LectureCard from '../components/LectureCard.astro'
import { getCollection } from 'astro:content'
import { createReader } from '@keystatic/core/reader'
import keystaticConfig from '../../keystatic.config'
import { lectureCategories } from '../utils/categoryLabels'

const reader = createReader(process.cwd(), keystaticConfig)

// Get lecture counts per category
const allLectures = await getCollection('lectures', ({ data }) => data.visibility === 'public')
const categoryCounts = new Map<string, number>()
allLectures.forEach((lecture) => {
	const cat = lecture.data.category
	if (cat) categoryCounts.set(cat, (categoryCounts.get(cat) || 0) + 1)
})

// Category icons mapping
const categoryIcons: Record<string, string> = {
	'general': 'mdi:book-open-variant',
	'algorithms-and-theory': 'mdi:function-variant',
	'systems-and-architecture': 'mdi:server',
	'error-correction-and-mitigation': 'mdi:shield-check',
	'compilation-and-optimization': 'mdi:cog-transfer',
	'machine-learning-and-ai': 'mdi:brain',
	'networking-and-communication': 'mdi:lan',
	'hardware-and-control': 'mdi:chip',
	'physics-and-simulation': 'mdi:atom',
	'software-tools-and-verification': 'mdi:wrench',
	'applications': 'mdi:application-brackets',
}

// Filter to categories with lectures and sort by count
const activeCategories = lectureCategories
	.filter((cat) => categoryCounts.get(cat.value) && categoryCounts.get(cat.value)! > 0)
	.map((cat) => ({
		...cat,
		count: categoryCounts.get(cat.value) || 0,
		icon: categoryIcons[cat.value] || 'mdi:folder',
	}))
	.sort((a, b) => b.count - a.count)

const lectures = (await getCollection('lectures', ({ data }) => {
	// Only show public lectures on homepage
	return data.visibility === 'public'
}))
	.sort((a, b) => b.data.lectureDate.valueOf() - a.data.lectureDate.valueOf())
	.slice(0, 4)

const homeData = await reader.singletons.home.read()
const socialData = await reader.singletons.social.read()

// Fallback to defaults if data not yet configured
const home = homeData || {
	welcomeText: 'Welcome to',
	heading: 'QuCS Lecture Series',
	subheading: 'A lecture series exploring quantum computing and its applications.',
	recentLecturesTitle: 'Recent Lectures',
	aboutSeriesTitle: 'About the Series',
	aboutSeriesText: 'Learn about our lecture series, its goals, and what topics we cover.',
	speakersTitle: 'Our Speakers',
	speakersText: 'Meet the experts and researchers presenting in our lecture series.',
	contactEmail: 'contact@example.com',
	registrationUrl: '',
	calendarUrl: '',
}

const socialLinks = socialData?.links || []
---

<BaseLayout>
	<main
		class="app-container flex flex-col gap-12 justify-center py-36 md:py-48 pt-44 md:pt-56 relative"
	>
		<div>
			<p class="block text-3xl opacity-70 mt-9 mb-4">{home.welcomeText}</p>
			<h1 class="text-8xl font-bold leading-none">{home.heading}</h1>
		</div>
		<p class="text-2xl max-w-2xl font-light leading-normal">
			{home.subheading}
		</p>
		<div class="flex flex-wrap gap-8">
			{
				socialLinks.map((link) => (
					<a
						class="text-xl text-primary dark:text-primary-dark underline hover:underline underline-offset-4"
						href={link.url}
						target="_blank"
					>
						{link.name}
					</a>
				))
			}
		</div>
	</main>

	<!-- Recent Lectures Section -->
	<section class="app-container">
		<h2 class="section-title">{home.recentLecturesTitle}</h2>
		<div class="posts-grid-container">
			{lectures.map((lecture) => <LectureCard lecture={lecture} />)}
		</div>
		<a class="btn-secondary" href={`${SITE_BASE}/lectures`}
			>View All Lectures
			<Icon size={20} name="mdi:arrow-right" />
		</a>
	</section>

	<!-- Explore by Topics Section -->
	<section class="app-container py-16">
		<h2 class="section-title">Explore by Topics</h2>
		<p class="text-lg max-w-2xl pb-6 opacity-80">
			Browse lectures by research area to find content that matches your interests.
		</p>
		<div class="flex flex-wrap gap-2">
			{activeCategories.map((category) => (
				<a
					href={`${SITE_BASE}/lectures/category/${category.value}`}
					class="group flex items-center gap-2 px-3 py-2 rounded-lg border border-foreground/10 dark:border-foreground-dark/10 hover:border-primary/30 dark:hover:border-primary-dark/30 hover:bg-primary/5 dark:hover:bg-primary-dark/5 transition-colors"
				>
					<Icon name={category.icon} class="w-4 h-4 text-primary dark:text-primary-dark" />
					<span class="text-sm font-medium group-hover:text-primary dark:group-hover:text-primary-dark transition-colors">
						{category.label}
					</span>
					<span class="text-xs text-foreground/40 dark:text-foreground-dark/40">
						{category.count}
					</span>
				</a>
			))}
		</div>
	</section>

	<!-- About Series & Speakers Section -->
	<section class="app-container py-42 grid lg:grid-cols-2 gap-28 lg:gap-10">
		<div class="space-y-6">
			<h2 class="section-title">{home.aboutSeriesTitle}</h2>
			<p class="text-lg max-w-xl pb-4">
				{home.aboutSeriesText}
			</p>
			<a class="btn-secondary" href={`${SITE_BASE}/about`}
				>Learn More
				<Icon size={20} name="mdi:arrow-right" />
			</a>
		</div>
		<div class="space-y-6">
			<h2 class="section-title">{home.speakersTitle}</h2>
			<p class="text-lg max-w-xl">
				{home.speakersText}
			</p>
			<div class="flex flex-wrap mt-auto gap-4">
				<a
					class="btn-primary"
					href={`mailto:${home.contactEmail}`}
					target="_blank"
					>Contact Us
					<Icon height={20} name="mdi:email" />
				</a>
				{home.calendarUrl && (
					<a class="btn-secondary" href={home.calendarUrl} target="_blank"
						>Subscribe to Calendar
						<Icon height={20} name="mdi:calendar" />
					</a>
				)}
				{home.registrationUrl && (
					<a class="btn-secondary" href={home.registrationUrl} target="_blank"
						>Register
						<Icon height={20} name="mdi:clipboard-list" />
					</a>
				)}
			</div>
		</div>
	</section>
</BaseLayout>
